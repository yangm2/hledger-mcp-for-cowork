{
  "permissions": {
    "allow": [
      "Bash(gh run:*)",
      "Bash(gh search:*)",
      "Bash(gh issue:*)",
      "WebFetch(domain:developer.apple.com)",
      "WebFetch(domain:docs.developer.apple.com)"
    ]
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "finance@knowledge-work-plugins": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
              "claude.com"
      ]
    }
  }
}
