{
  "permissions": {
    "allow": [
      "Bash(gh run:*)",
      "Bash(gh search:*)",
      "Bash(gh issue:*)",
      "Bash(mise run:*)",
      "Skill(hookify:hookify)",
      "Skill(hookify:hookify:*)",
      "WebFetch(domain:developer.apple.com)",
      "WebFetch(domain:docs.developer.apple.com)",
      "WebFetch(domain:static.crates.io)",
      "WebFetch(domain:static.rust-lang.org)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:index.crates.io)",
      "Bash(rustup target *)",
      "Bash(python3 -)",
      "Bash(echo \"exit=$?\")",
      "WebFetch(domain:mise.en.dev)",
      "Skill(code-review)",
      "Skill(code-review:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/rust-quality-gate.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "finance@knowledge-work-plugins": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "claude.com",
        "crates.io"
      ]
    }
  }
}
