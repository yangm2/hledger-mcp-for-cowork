/target

# nix
/result
/result-*
.direnv/

# materialized dev env (from `nix print-dev-env`)
/.devenv.sh

# per-clone env file (absolute path to the pinned hledger binary)
/.env.local

# captured unified-log streams (may contain ledger data; never commit — public repo)
/.debug/

# cargo-mutants working output (`mise run mutants` / `mutants-diff`): per-mutant diffs,
# logs, outcomes.json — regenerable, plus the `.old` copy from the previous run.
/mutants.out*/

# cross-process write lockfile (M3): created beside any journal a server/e2e touches;
# kernel lock state, never tracked (the fixtures journal picks one up from the stdio e2e)
.hledger-mcp.lock
